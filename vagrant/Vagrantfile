Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "lfcs-lab"

  config.vm.provider "virtualbox" do |vb|
    vb.name   = "lfcs-lab"
    vb.memory = 2048
    vb.cpus   = 2
  end

  config.vm.network "private_network", ip: "192.168.56.10"

  config.vm.provision "shell", inline: <<-SHELL
    apt-get update -q
    apt-get install -y -q \
      vim curl wget git htop tree \
      net-tools iproute2 dnsutils \
      systemd-container lvm2 \
      firewalld ufw \
      python3 python3-pip
    echo "LFCS lab VM ready. SSH in with: vagrant ssh"
  SHELL
end
