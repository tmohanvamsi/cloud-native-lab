# Local secrets — never commit these
.env.local
*.env
secrets/

# Vagrant
vagrant/.vagrant/

# Terraform
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/.terraform.lock.hcl

# kubeconfig backups
*.kubeconfig
kubeconfig

# Helm chart caches
charts/
*.tgz

